# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

GROQ_API_KEY=gsk_your_groq_key_here

# Metered.ca TURN server — get free at app.metered.ca
METERED_API_KEY=your_metered_api_key_here
METERED_APP_NAME=your_app_name_here
# Example: if your app is "interviewai" → METERED_APP_NAME=interviewai
# Your TURN host will be: interviewai.metered.live
